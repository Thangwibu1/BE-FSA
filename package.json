{
  "name": "movie-theater-fastify",
  "version": "1.0.0",
  "description": "Clean-Architecture Fastify + MongoDB backend for the Movie Theater app (json-server compatible)",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "node --check src/server.js",
    "migrate": "node src/infrastructure/db/migrate.js up",
    "migrate:status": "node src/infrastructure/db/migrate.js status",
    "seed": "node src/infrastructure/db/seed.js --if-empty",
    "seed:fresh": "node src/infrastructure/db/seed.js --fresh && node src/infrastructure/db/reseedShowtimes.js",
    "seed:showtimes": "node src/infrastructure/db/reseedShowtimes.js",
    "seed:promotions": "node src/infrastructure/db/seedPromotions.js",
    "db:setup": "npm run seed",
    "db:reset": "npm run seed:fresh",
    "test": "node --test --test-concurrency=1 --test-reporter=spec test/api.test.js test/database.test.js test/showtimeSchedule.test.js test/full-api.integration.test.js",
    "test:remote": "node --test --test-concurrency=1 --test-reporter=spec test/remote.integration.test.js",
    "test:all": "npm test && npm run test:remote",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "fastify",
    "mongodb",
    "clean-architecture",
    "movie-theater",
    "json-server"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "minio": "^8.0.7",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0"
  }
}
