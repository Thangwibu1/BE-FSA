# Public API port on the Docker host.
API_PORT=5550

# MongoDB container credentials. Use URL-safe values because they are embedded
# in MONGODB_URI by docker-compose.yml.
MONGO_ROOT_USERNAME=movie_theater
MONGO_ROOT_PASSWORD=replace_with_a_strong_url_safe_password
MONGO_DB_NAME=movie_theater

# Generate a long random value for production, for example:
#   openssl rand -hex 64
AUTH_TOKEN_SECRET=replace_with_at_least_64_random_characters
AUTH_TOKEN_LIFETIME_SECONDS=28800
AUTH_REFRESH_TOKEN_LIFETIME_SECONDS=2592000

CORS_ORIGIN=*
LOG_LEVEL=info
MAX_IMAGE_UPLOAD_BYTES=5242880
