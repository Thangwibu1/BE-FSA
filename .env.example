# --- Server ---
PORT=5550
HOST=0.0.0.0

# --- MongoDB (single connection string, DB name included at the end) ---
MONGODB_URI=mongodb://127.0.0.1:27017/movie_theater
MONGODB_DB_NAME=movie_theater_fastify
RUN_MIGRATIONS=true

# --- CORS ---
CORS_ORIGIN=*

# --- Logging ---
LOG_LEVEL=info

# --- Authentication ---
# Use a long random secret outside local development.
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_LIFETIME_SECONDS=28800
AUTH_REFRESH_TOKEN_LIFETIME_SECONDS=2592000

# --- Image uploads (movie, employee and promotion images) ---
UPLOAD_DIR=./uploads
MAX_IMAGE_UPLOAD_BYTES=5242880

# --- MinIO Object Storage ---
